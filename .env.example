# Required
BOT_TOKEN=replace-with-your-telegram-bot-token
APP_SECRET=replace-with-a-long-random-secret
PG_DSN=postgres://relaybot:relaybot@127.0.0.1:5432/relaybot?sslmode=disable

# Redis
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0
# Compose host published port for redis service (compose.yaml / compose-dev.yaml)
# HOST_REDIS_PORT=6379

# HTTP server
HTTP_ADDR=:8080
# For docker compose -f compose.yaml -f compose-app.yaml:
# HOST_HTTP_PORT controls the host exposed port.
# CONTAINER_HTTP_PORT controls the app listen port in container.
# HOST_HTTP_PORT=18080
# CONTAINER_HTTP_PORT=8080
# COMPOSE_HTTP_ADDR overrides HTTP_ADDR only for compose-app.yaml.
# COMPOSE_HTTP_ADDR=:8080

# For docker compose -f compose.yaml:
# HOST_POSTGRES_PORT controls the host exposed postgres port.
# HOST_POSTGRES_PORT=5432

# For docker compose -f compose.yaml -f compose-app.yaml:
# COMPOSE_PG_DSN and COMPOSE_REDIS_ADDR override PG_DSN / REDIS_ADDR
# only inside the relaybot container (to avoid 127.0.0.1 confusion).
# COMPOSE_PG_DSN=postgres://relaybot:relaybot@postgres:5432/relaybot?sslmode=disable
# COMPOSE_REDIS_ADDR=redis:6379

# Telegram webhook
# Leave WEBHOOK_BASE_URL / WEBHOOK_PUBLIC_URL empty to use long polling locally.
WEBHOOK_PATH=/telegram/webhook
WEBHOOK_SECRET=
# WEBHOOK_BASE_URL=https://your-domain.example.com
# WEBHOOK_PUBLIC_URL=https://your-domain.example.com

# Telegram bot commands
SYNC_BOT_COMMANDS=true

# Relay behavior
RELAY_TTL=24h
MAX_FILE_BYTES=10737418240
ACTIVE_RELAYS_PER_USER=100
MAX_BATCH_ITEMS=100

# Rate limits
UPLOAD_RATE_LIMIT=1000
UPLOAD_RATE_WINDOW=10m
CLAIM_RATE_LIMIT=1000
CLAIM_RATE_WINDOW=10m
BAD_CODE_RATE_LIMIT=100
BAD_CODE_RATE_WINDOW=10m

# Background jobs
BATCH_SESSION_TTL=30m
STALE_DELIVERY_AFTER=2m
EXPIRED_DELIVERY_RETAIN=168h

# File policy
ALLOW_DANGEROUS_FILES=false
BLOCKED_EXTENSIONS=.exe,.msi,.bat,.cmd,.sh,.apk,.dmg,.iso,.js
