# Required
BOT_TOKEN=replace-with-your-telegram-bot-token
APP_SECRET=replace-with-a-long-random-secret
PG_DSN=postgres://relaybot:relaybot@127.0.0.1:5432/relaybot?sslmode=disable

# Redis
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# HTTP server
HTTP_ADDR=:8080

# Telegram webhook
# Leave WEBHOOK_BASE_URL / WEBHOOK_PUBLIC_URL empty to use long polling locally.
WEBHOOK_PATH=/telegram/webhook
WEBHOOK_SECRET=
# WEBHOOK_BASE_URL=https://your-domain.example.com
# WEBHOOK_PUBLIC_URL=https://your-domain.example.com

# Telegram bot commands
SYNC_BOT_COMMANDS=true

# Relay behavior
RELAY_TTL=24h
MAX_FILE_BYTES=1073741824
ACTIVE_RELAYS_PER_USER=100

# Rate limits
UPLOAD_RATE_LIMIT=5
UPLOAD_RATE_WINDOW=10m
CLAIM_RATE_LIMIT=15
CLAIM_RATE_WINDOW=10m
BAD_CODE_RATE_LIMIT=10
BAD_CODE_RATE_WINDOW=10m

# Background jobs
STALE_DELIVERY_AFTER=2m
EXPIRED_DELIVERY_RETAIN=168h

# File policy
ALLOW_DANGEROUS_FILES=false
BLOCKED_EXTENSIONS=.exe,.msi,.bat,.cmd,.sh,.apk,.dmg,.iso,.js
